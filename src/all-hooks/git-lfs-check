#!/usr/bin/python3

"""
Custom Git LFS hook that enforces .gitattributes:
It rejects files that should be in LFS based on .gitattributes
but were committed as regular Git objects and vice-versa.

It does NOT verify the integrity of LFS objects on disk.
"""

import subprocess
import sys
from typing import Dict, List

from osc.gitea_api import Git


class LfsChecker:
    def __init__(self, git: Git):
        self.git = git
        self.cache: Dict[str, bool] = {}

    def get_attributes(self, rev: str, paths: List[str]) -> Dict[str, str]:
        """Query git check-attr for the 'filter' attribute."""
        if not paths:
            return {}

        with subprocess.Popen(
            ["git", "check-attr", "--source", rev, "--stdin", "filter"],
            cwd=self.git.abspath,
            stdin=subprocess.PIPE,
            stdout=subprocess.PIPE,
            stderr=sys.stderr,
            encoding="utf-8",
        ) as proc:

            stdout, _ = proc.communicate(input="\n".join(paths))
            if proc.returncode != 0:
                raise RuntimeError(f"git check-attr failed for revision {rev}")

        results = {}
        for line in stdout.splitlines():
            # format: <path>: filter: <value>
            # git uses ': ' (colon + space) as a reliable separator
            try:
                path, attr, value = line.split(": ", 2)
            except ValueError:
                # failed to split line into exactly 3 parts
                raise RuntimeError(f"Malformed output from git check-attr: '{line}'")

            if attr != "filter":
                raise RuntimeError(f"Unexpected attribute in git check-attr output: '{attr}'")

            # Git may quote paths with special characters (core.quotepath).
            if path.startswith('"') and path.endswith('"'):
                # handle git's octal/hex escaping
                try:
                    path = path[1:-1].encode("utf-8").decode("unicode_escape")
                except Exception:
                    path = path[1:-1]

            results[path] = value
        return results

    def verify_blobs(self, rev: str, file_to_hash: Dict[str, str], hash_to_size: Dict[str, int], attrs: Dict[str, str]):
        """Verify LFS compliance for a set of files using batched cat-file."""
        to_check = []
        unique_hashes = set()

        for h in file_to_hash.values():
            if h in self.cache or h in unique_hashes:
                continue

            # PREPROCESSING: LFS pointers are tiny (< 1KB), skip any larger blobs
            if hash_to_size.get(h, 0) > 1024:
                self.cache[h] = False
                continue

            to_check.append(h)
            unique_hashes.add(h)

        if to_check:
            # NOTE: We must use binary mode (bytes) for cat-file --batch because:
            # 1. Blobs can contain arbitrary binary data that is not valid UTF-8.
            # 2. Git reports object size in BYTES. If we used text mode (encoding="utf-8"),
            #    read(size) would read 'size' CHARACTERS, which breaks protocol parsing
            #    whenever a multi-byte UTF-8 character is encountered.
            with subprocess.Popen(
                ["git", "cat-file", "--batch"],
                cwd=self.git.abspath,
                stdin=subprocess.PIPE,
                stdout=subprocess.PIPE,
                stderr=sys.stderr,
                bufsize=1024 * 1024,
            ) as proc:

                stdout_stream, _ = proc.communicate(input=("\n".join(to_check) + "\n").encode("utf-8"))
                if proc.returncode != 0:
                    raise RuntimeError("git cat-file --batch failed")

            # parse the combined output buffer without slicing (zero-copy approach)
            offset = 0
            prefix = b"version https://git-lfs.github.com/spec/v1"
            for h in to_check:
                newline_idx = stdout_stream.find(b"\n", offset)
                if newline_idx == -1:
                    raise RuntimeError(f"git cat-file output truncated, expected object {h}")

                header = stdout_stream[offset:newline_idx].decode("utf-8")
                try:
                    _hash, _type, size = header.split()
                    size = int(size)
                except ValueError:
                    raise RuntimeError(f"Malformed git cat-file header or missing object: '{header}'")
                content_start = newline_idx + 1
                content_end = content_start + size

                # verify LFS status directly in the buffer using offsets
                self.cache[h] = stdout_stream.startswith(prefix, content_start, content_end)

                offset = content_end + 1

        # validation phase
        errors = []
        for path, h in file_to_hash.items():
            should_be_lfs = attrs.get(path) == "lfs"
            is_lfs = self.cache.get(h, False)

            if should_be_lfs and not is_lfs:
                errors.append(f"  - {path}: matches LFS attribute but is NOT an LFS pointer")
            elif not should_be_lfs and is_lfs:
                errors.append(f"  - {path}: is NOT matched by LFS attribute but IS an LFS pointer")

        if errors:
            print(f"LFS compliance errors in commit {rev}:", file=sys.stderr)
            for err in errors:
                print(err, file=sys.stderr)
            return False
        return True

    def check_revision(self, rev: str) -> bool:
        """Check if the specified revision is LFS compliant."""
        try:
            self.git._run_git(["cat-file", "-e", f"{rev}:.gitattributes"], mute_stderr=True)
        except subprocess.CalledProcessError:
            return True

        tree_entries = self.git.ls_tree(rev)
        file_to_hash = {}
        hash_to_size = {}
        for item in tree_entries:
            if item["file_type"] != "file":
                continue
            path = item["path"]
            h = item["commit"]
            file_to_hash[path] = h
            hash_to_size[h] = item["size"]

        if not file_to_hash:
            return True

        attrs = self.get_attributes(rev, list(file_to_hash.keys()))
        return self.verify_blobs(rev, file_to_hash, hash_to_size, attrs)


def main():
    git = Git(".")
    checker = LfsChecker(git)
    seen = set()
    success = True

    for old_rev, new_rev, _ref_name in git.parse_githook_stdin():
        commits = git.get_commit_range(old_rev, new_rev, not_all=True)
        for sha in commits:
            if sha in seen:
                continue
            success &= checker.check_revision(sha)
            seen.add(sha)

    if not success:
        sys.exit(1)


if __name__ == "__main__":
    main()
