#!/bin/bash


# Check if all new git commits don't contain forbidden files:
# - .osc
# - _scmsync.obsinfo
# - build.specials.obscpio


set -euo pipefail

echo "Running hook: $(basename $0)"

FORBIDDEN_PATTERN='(^|/)(\.osc|_scmsync\.obsinfo|build\.specials\.obscpio)($|/)'

while read -r old_rev new_rev ref_name; do

    # Skip on branch deletion.
    [[ "$new_rev" =~ ^0+$ ]] && continue

    # Handle branch creation.
    branch_create=false
    base_revs="$old_rev"
    if [[ "${old_rev}" =~ ^0+$ ]]; then
        branch_create=true
        base_revs=$(git for-each-ref --format='%(objectname)' | sort -u | xargs)
    fi

    # Limit range to only new commits relative to repository history.
    revs_to_check="$new_rev"
    merge_base=$(git merge-base "${new_rev}" ${base_revs} 2>/dev/null | head -n1 || true)
    [ -n "$merge_base" ] && revs_to_check=$(git rev-list --first-parent "${merge_base}..${new_rev}")

    # For new branch pushes, ensure the tip tree is clean.
    if [ "$branch_create" = true ]; then
        tip_files=$(git ls-tree -r --name-only "${new_rev}")
        tip_matches=$(printf '%s\n' "$tip_files" | grep -E "${FORBIDDEN_PATTERN}" || :)
        if [ -n "${tip_matches}" ]; then
            echo "ERROR: Forbidden file or directory found in tip ${new_rev}" >&2
            echo "${tip_matches}" >&2
            exit 1
        fi
    fi

    failed=0
    while read -r commit; do
        [ -z "$commit" ] && continue

        matches=$(git show --pretty="" --name-only --diff-filter=AM "${commit}" | grep -E "${FORBIDDEN_PATTERN}" || :)
        if [ -n "${matches}" ]; then
            # On new branch pushes with no merge-base, allow forbidden files that were deleted before tip.
            if [ "$branch_create" = true ] && [ -z "$merge_base" ]; then
                matches=$(printf '%s\n' "$matches" | grep -F -f <(printf '%s\n' "$tip_files") || :)
            fi
            if [ -n "${matches}" ]; then
                echo "ERROR: Forbidden file or directory found in commit ${commit}" >&2
                echo "${matches}" >&2
                failed=1
            fi
        fi
    done <<< "$revs_to_check"

    [ "$failed" -eq 1 ] && exit 1
done

exit 0
